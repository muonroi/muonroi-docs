{
  "_comment": "Root paths to crawl, relative to D:/sources/Core/. Glob patterns per entry.",
  "roots": [
    {
      "path": "muonroi-docs/docs",
      "glob": "**/*.md",
      "label": "muonroi-docs"
    },
    {
      "path": "muonroi-building-block",
      "glob": "**/README.md",
      "label": "bb-readme"
    },
    {
      "path": "muonroi-building-block",
      "glob": "**/Agent.md",
      "label": "bb-agent"
    },
    {
      "path": "muonroi-building-block",
      "glob": "**/AGENTS.md",
      "label": "bb-agents"
    },
    {
      "path": "muonroi-building-block",
      "glob": "**/EE-INTENT.md",
      "label": "bb-ee-intent"
    },
    {
      "path": "muonroi-cli/packages",
      "glob": "**/README.md",
      "label": "cli-harness"
    },
    {
      "path": "muonroi-cli",
      "glob": "CLAUDE.md",
      "label": "cli-claude"
    },
    {
      "path": "muonroi-cli",
      "glob": "AGENTS.md",
      "label": "cli-agents"
    },
    {
      "path": "muonroi-cli/docs",
      "glob": "**/*.md",
      "label": "cli-docs"
    },
    {
      "path": "muonroi-docs/mcp/recipes",
      "glob": "*.md",
      "label": "setup-recipes"
    }
  ],
  "skip": ["node_modules", "bin", "obj", ".git", "dist", "build", ".vs", ".claude", "worktrees"]
}
